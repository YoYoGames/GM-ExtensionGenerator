<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Resources\Cmake\.clang-format" />
    <None Remove="Resources\Cmake\CMakeLists.txt" />
    <None Remove="Resources\Cmake\CMakePresets.json" />
