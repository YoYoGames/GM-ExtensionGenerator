  <ItemGroup>
    <Reference Include="Antlr4.Runtime">
      <HintPath>Dependencies\Antlr4.Runtime.dll</HintPath>
    </Reference>
    <Reference Include="Antlr4.Runtime.Standard">
      <HintPath>Dependencies\Antlr4.Runtime.Standard.dll</HintPath>
    </Reference>
    <Reference Include="gmidl">
      <HintPath>..\..\..\GMRT\build\libs_x86_64-pc-windows-msvc\Release\bin\gmidl.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="gmidlparser">
      <HintPath>..\..\..\GMRT\build\libs_x86_64-pc-windows-msvc\Release\bin\gmidlparser.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="gmidlreader">
      <HintPath>..\..\..\GMRT\build\libs_x86_64-pc-windows-msvc\Release\bin\gmidlreader.dll</HintPath>
      <Private>True</Private>
