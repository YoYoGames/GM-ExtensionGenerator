    <EmbeddedResource Include="Resources\Cmake\CMakePresets.json">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </EmbeddedResource>
    <EmbeddedResource Include="Resources\Cmake\cmake\extgen_package_xcframework.cmake" />
    <EmbeddedResource Include="Resources\Cmake\cmake\extgen_xcframework.cmake" />
    <EmbeddedResource Include="Resources\Cmake\src\CMakeLists.txt">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </EmbeddedResource>
    <EmbeddedResource Include="Resources\Cmake\third_party\CMakeLists.txt">
