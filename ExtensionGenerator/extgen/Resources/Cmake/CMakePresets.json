    },
    {
      "name": "xbox-one-release",
      "displayName": "Xbox One Release",
      "hidden": ${EXTGEN_XBOX_DISABLED},
      "inherits": "base-vs",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_VS_PLATFORM_NAME": "Gaming.Xbox.X64"
      }
    },


    {
      "name": "ps4-debug",
      "displayName": "PlayStation 4 (ORBIS) Debug",
      "hidden": ${EXTGEN_PS4_DISABLED},
      "inherits": "base-ninja",
      "toolchainFile": "$env{SCE_ORBIS_SDK_DIR}/target/sce_orbis.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_SYSTEM_NAME": "ORBIS"
      }
    },
    {
      "name": "ps4-release",
      "displayName": "PlayStation 4 (ORBIS) Release",
      "hidden": ${EXTGEN_PS4_DISABLED},
      "inherits": "base-ninja",
      "toolchainFile": "$env{SCE_ORBIS_SDK_DIR}/target/sce_orbis.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_SYSTEM_NAME": "ORBIS"
      }
    },


    {
      "name": "ps5-debug",
      "displayName": "PlayStation 5 (Prospero) Debug",
      "hidden": ${EXTGEN_PS5_DISABLED},
      "inherits": "base-ninja",
      "toolchainFile": "$env{SCE_PROSPERO_SDK_DIR}/target/sce_prospero.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_SYSTEM_NAME": "Prospero"
      }
    },
    {
      "name": "ps5-release",
      "displayName": "PlayStation 5 (Prospero) Release",
      "hidden": ${EXTGEN_PS5_DISABLED},
      "inherits": "base-ninja",
