      "name": "xbox-scarlett-debug",
      "displayName": "Xbox Series (Scarlett) Debug",
      "hidden": ${EXTGEN_XBOX_DISABLED},
      "inherits": "base-vs",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_VS_PLATFORM_NAME": "Gaming.Xbox.Scarlett.x64"
      }
    },
    {
      "name": "xbox-scarlett-release",
      "displayName": "Xbox Series (Scarlett) Release",
      "hidden": ${EXTGEN_XBOX_DISABLED},
      "inherits": "base-vs",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
