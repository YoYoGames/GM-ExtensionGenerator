    {
      "name": "switch-debug",
      "displayName": "Nintendo Switch Debug",
      "hidden": ${EXTGEN_SWITCH_DISABLED},
      "inherits": "base-ninja",
      "toolchainFile": "$env{NINTENDO_SDK_ROOT}/Compilers/NX/nx64.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_SYSTEM_NAME": "NintendoSwitch",
        "CMAKE_TRY_COMPILE_TARGET_TYPE": "STATIC_LIBRARY"
